class Solution {
public:
    bool repeatedSubstringPattern(string s) {
        
        int n = s.length();
        for(int i=1; i <= n/2; i++){

            string temp = "";
            string part = s.substr(0,i);

            for(int j=0; j < n/i; j++){
                temp += part;
            }

            if(temp == s){
                return true;
            }

        }
        return false;
    }

};
