class Solution {
public:
    int maxArea(vector<int>& height) {
        int s = 0;
        int e = height.size() - 1;
        int ans = 0;

        while (s < e) {
            int remaining_part = e - s;
            int h = min(height[s], height[e]);

            ans = max(ans, remaining_part * h);

            if (height[s] < height[e]){
                s++;
            }
            else{
                e--;
            }
        }

        return ans;
    }
};
